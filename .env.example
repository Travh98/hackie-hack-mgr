# Discord bot token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Anthropic — used when config.json "provider" is "anthropic"
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI-compatible — used when config.json "provider" is "openai"
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=                        # optional: set for Azure, Ollama, etc.

# Optional: set your Discord server ID for instant slash command sync during dev
# Leave blank for global sync (takes up to 1 hour to propagate)
GUILD_ID=
